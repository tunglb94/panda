# FAIRRIDE — Local Development Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env — it is in .gitignore.

# ─── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_USER=fairride
POSTGRES_PASSWORD=fairride_dev_secret
POSTGRES_DB=fairride
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────
REDIS_PASSWORD=fairride_redis_secret
REDIS_PORT=6379

# ─── Kafka ────────────────────────────────────────────────────────
KAFKA_EXTERNAL_PORT=9094
KAFKA_UI_PORT=8090

# ─── Service — Identity (port: gRPC 50051, HTTP 8001) ─────────────
IDENTITY_DATABASE_URL=postgres://fairride:fairride_dev_secret@localhost:5432/identity_db
IDENTITY_GRPC_ADDR=:50051
IDENTITY_HTTP_ADDR=:8001

# ─── Service — User (port: gRPC 50052, HTTP 8002) ─────────────────
USER_DATABASE_URL=postgres://fairride:fairride_dev_secret@localhost:5432/user_db
USER_GRPC_ADDR=:50052
USER_HTTP_ADDR=:8002

# ─── Service — Driver (port: gRPC 50053, HTTP 8003) ───────────────
DRIVER_DATABASE_URL=postgres://fairride:fairride_dev_secret@localhost:5432/driver_db
DRIVER_GRPC_ADDR=:50053
DRIVER_HTTP_ADDR=:8003

# ─── Service — Trip (port: gRPC 50054, HTTP 8004) ─────────────────
TRIP_DATABASE_URL=postgres://fairride:fairride_dev_secret@localhost:5432/trip_db
TRIP_GRPC_ADDR=:50054
TRIP_HTTP_ADDR=:8004

# ─── Service — Dispatch (port: gRPC 50055, HTTP 8005) ─────────────
DISPATCH_DATABASE_URL=postgres://fairride:fairride_dev_secret@localhost:5432/dispatch_db
DISPATCH_GRPC_ADDR=:50055
DISPATCH_HTTP_ADDR=:8005

# ─── Service — Geo (port: gRPC 50056, HTTP 8006) ──────────────────
GEO_DATABASE_URL=postgres://fairride:fairride_dev_secret@localhost:5432/geo_db
GEO_GRPC_ADDR=:50056
GEO_HTTP_ADDR=:8006

# ─── Service — Pricing (port: gRPC 50057, HTTP 8007) ──────────────
PRICING_DATABASE_URL=postgres://fairride:fairride_dev_secret@localhost:5432/pricing_db
PRICING_GRPC_ADDR=:50057
PRICING_HTTP_ADDR=:8007

# ─── Service — Wallet (port: gRPC 50058, HTTP 8008) ───────────────
WALLET_DATABASE_URL=postgres://fairride:fairride_dev_secret@localhost:5432/wallet_db
WALLET_GRPC_ADDR=:50058
WALLET_HTTP_ADDR=:8008

# ─── Service — Payment (port: gRPC 50059, HTTP 8009) ──────────────
PAYMENT_DATABASE_URL=postgres://fairride:fairride_dev_secret@localhost:5432/payment_db
PAYMENT_GRPC_ADDR=:50059
PAYMENT_HTTP_ADDR=:8009

# ─── Service — Promotion (port: gRPC 50060, HTTP 8010) ────────────
PROMOTION_DATABASE_URL=postgres://fairride:fairride_dev_secret@localhost:5432/promotion_db
PROMOTION_GRPC_ADDR=:50060
PROMOTION_HTTP_ADDR=:8010

# ─── Service — Notification (port: gRPC 50061, HTTP 8011) ─────────
NOTIFICATION_DATABASE_URL=postgres://fairride:fairride_dev_secret@localhost:5432/notification_db
NOTIFICATION_GRPC_ADDR=:50061
NOTIFICATION_HTTP_ADDR=:8011

# ─── Service — Review (port: gRPC 50062, HTTP 8012) ───────────────
REVIEW_DATABASE_URL=postgres://fairride:fairride_dev_secret@localhost:5432/review_db
REVIEW_GRPC_ADDR=:50062
REVIEW_HTTP_ADDR=:8012

# ─── Service — Analytics (port: gRPC 50063, HTTP 8013) ────────────
ANALYTICS_DATABASE_URL=postgres://fairride:fairride_dev_secret@localhost:5432/analytics_db
ANALYTICS_GRPC_ADDR=:50063
ANALYTICS_HTTP_ADDR=:8013

# ─── Service — Admin (port: gRPC 50064, HTTP 8014) ────────────────
ADMIN_DATABASE_URL=postgres://fairride:fairride_dev_secret@localhost:5432/admin_db
ADMIN_GRPC_ADDR=:50064
ADMIN_HTTP_ADDR=:8014

# ─── Common ───────────────────────────────────────────────────────
LOG_LEVEL=info
ENVIRONMENT=development
REDIS_ADDR=localhost:6379
KAFKA_BROKERS=localhost:9094
